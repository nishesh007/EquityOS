# EquityOS Environment Configuration
# Copy this file to .env.local and fill in your API keys.
# When no keys are configured, the app automatically uses the Free provider.

# ── Provider Selection ──────────────────────────────────────────────
# Primary quote provider: nse | finnhub | bse | free
# When no API keys are configured, the Free provider is used automatically.
MARKET_PROVIDER_PRIMARY=nse
# Secondary fallback provider: finnhub | bse | nse | free
MARKET_PROVIDER_SECONDARY=finnhub

# ── Fundamentals Providers (Sprint 7B) ──────────────────────────────
# Primary fundamentals provider: fmp | alphavantage | mock
FUNDAMENTALS_PROVIDER_PRIMARY=fmp
# Secondary fundamentals fallback: alphavantage | fmp | mock
FUNDAMENTALS_PROVIDER_SECONDARY=alphavantage

# ── NSE India ─────────────────────────────────────────────────────
NSE_ENABLED=false
NSE_API_BASE_URL=https://www.nseindia.com/api

# ── BSE India ─────────────────────────────────────────────────────
BSE_ENABLED=false
BSE_API_BASE_URL=https://api.bseindia.com

# ── Finnhub (Secondary / Global Quotes) ─────────────────────────────
FINNHUB_API_KEY=your_api_key_here
FINNHUB_API_BASE_URL=https://finnhub.io/api/v1

# ── Polygon (OHLC / Historical Candles) ─────────────────────────────
POLYGON_API_KEY=your_api_key_here
POLYGON_API_BASE_URL=https://api.polygon.io

# ── Alpha Vantage (Fundamentals Fallback) ───────────────────────────
ALPHA_VANTAGE_API_KEY=your_api_key_here
ALPHA_VANTAGE_API_BASE_URL=https://www.alphavantage.co/query

# ── Financial Modeling Prep (Fundamentals) ──────────────────────────
FMP_API_KEY=your_api_key_here
FMP_API_BASE_URL=https://financialmodelingprep.com/api/v3

# ── OpenAI (AI Insights — Sprint 8+) ────────────────────────────────
OPENAI_API_KEY=your_api_key_here
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_MS=45000
OPENAI_MAX_RETRIES=2

# ── AI Platform Security / Performance ─────────────────────────────
AI_RATE_LIMIT_PER_MINUTE=30
AI_MAX_PROMPT_CHARS=8000
AI_CONFIDENCE_THRESHOLD=45

# ── Institutional RAG (pgvector) ────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/equityos
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072
RAG_TOP_K=10

# ── TradingView Widget ──────────────────────────────────────────────
# Set to true to enable the embedded TradingView chart on company pages.
# When false or on failure, the local candlestick chart is used automatically.
NEXT_PUBLIC_ENABLE_TRADINGVIEW=false
